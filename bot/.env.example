# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
MANAGER_CHAT_ID=telegram_chat_id_of_anh_huy

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Dashboard API ─────────────────────────────────────────────────────────────
# Phải khớp với NEXT_PUBLIC_API_SECRET trong web/.env.local
DASHBOARD_SECRET=ops-tasks-secret-change-me

# ─── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/ops_tasks.db

# ─── Scheduler ─────────────────────────────────────────────────────────────────
QUIET_HOURS_START=22
QUIET_HOURS_END=6

# ─── KPI data sources (cả 2 đều optional — pick 1) ────────────────────────────
# Google Sheet (đơn giản nhất, recommended): manager paste KPI sáng vào sheet
GSHEET_ID=                                # long ID trong URL sheet
GSHEET_TAB=0                              # gid (số) hoặc tên tab worksheet
# Service account JSON: path tới file HOẶC inline JSON. Bỏ trống nếu dùng public CSV.
GSHEET_SERVICE_ACCOUNT_JSON=

# Redash (nếu team dùng Redash thay vì sheet)
# REDASH_URL=https://redash.your-domain.com
# REDASH_API_KEY=your_redash_api_key
# REDASH_QUERY_METRICS=123                # query trả về metric_key, value (recommended)

# ─── Auto-decision (manager unblock) ──────────────────────────────────────────
# Khi forward task tin nhắn: nếu conf ≥ THRESHOLD và priority ≤ MAX_PRIORITY,
# bot tự tạo task không cần manager click. P0/P1 luôn confirm dù conf cao.
AUTO_DECISION_THRESHOLD=0.85
AUTO_DECISION_MAX_PRIORITY=P2             # P0|P1|P2|P3 (P2 = auto cho P2 và P3)
AUTO_DECISION_UNDO_WINDOW_MIN=60          # phút manager có thể /undo task auto-tạo

# ─── Ad-hoc cap (warning khi vượt) ────────────────────────────────────────────
ADHOC_CAP=15                              # % task ad-hoc tối đa/tuần

# ─── Twilio (chỉ dùng cho manager call alerts) ────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1234567890
# MANAGER_PHONE=+84xxxxxxxxx
