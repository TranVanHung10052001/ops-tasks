# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
MANAGER_CHAT_ID=telegram_chat_id_of_anh_huy

# ─── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Dashboard API ─────────────────────────────────────────────────────────────
# Phải khớp với NEXT_PUBLIC_API_SECRET trong web/.env.local
DASHBOARD_SECRET=ops-tasks-secret-change-me

# ─── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/ops_tasks.db

# ─── Scheduler ─────────────────────────────────────────────────────────────────
QUIET_HOURS_START=22
QUIET_HOURS_END=6

# ─── Twilio (chỉ dùng cho manager call alerts) ────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM=+1234567890
# MANAGER_PHONE=+84xxxxxxxxx
